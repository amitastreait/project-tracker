<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ExecutionMode__c</fullName>
    <description>Determines whether the step runs as a Queueable or a Batch job. Batch is recommended for large data volumes.</description>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <label>Execution Mode</label>
    <required>true</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Queueable</fullName>
                <default>true</default>
                <label>Queueable</label>
            </value>
            <value>
                <fullName>Batch</fullName>
                <default>false</default>
                <label>Batch</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
